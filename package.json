{
  "name": "nebula-notebook",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "server": "cd server && python -m uvicorn main:app --reload --host 0.0.0.0 --port 8000",
    "server:prod": "cd server && python main.py",
    "setup": "node setup.cjs",
    "prestart": "node setup.cjs",
    "start": "concurrently --kill-others --kill-signal SIGTERM --raw \"npm run server\" \"npm run dev\"",
    "start:prod": "npm run build && npm run server:prod",
    "stop": "lsof -ti:3000,8000 | xargs kill -9 2>/dev/null; echo 'Servers stopped'",
    "test": "vitest",
    "test:run": "vitest run"
  },
  "dependencies": {
    "@codemirror/lang-markdown": "^6.5.0",
    "@codemirror/lang-python": "^6.2.1",
    "@uiw/react-codemirror": "^4.25.4",
    "diff-match-patch": "^1.0.5",
    "lucide-react": "^0.561.0",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "react-virtuoso": "^4.17.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.57.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.1",
    "@types/diff-match-patch": "^1.0.36",
    "@types/node": "^22.14.0",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.0.0",
    "concurrently": "^9.1.0",
    "jsdom": "^27.3.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.0",
    "vitest": "^4.0.16"
  }
}
